---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CSS Toggle Library — pure-CSS switches, checkboxes & radios, free to copy',
  description = 'A library of pure-CSS toggles, switches, checkboxes and radios — no JavaScript, no dependencies. Click any toggle to view and copy its self-contained CSS.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Self-hosted fonts. Preload the above-the-fold weights (Inter 500 powers
         the hero h1 / LCP element; Inter 400 the body copy) so they arrive
         before paint and the headline doesn't swap late. @font-face lives in
         the inlined global.css. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-500-normal.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-400-normal.woff2" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
